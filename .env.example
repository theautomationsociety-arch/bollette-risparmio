# BollettaAI — Variabili d'ambiente
# Copia questo file in .env e compila i valori
# cp .env.example .env

# ── OBBLIGATORIO ──────────────────────────────────────────────
# Chiave API Google Gemini (gratuita su https://aistudio.google.com/apikey)
GEMINI_API_KEY=la-tua-chiave-gemini-qui

# ── SICUREZZA ─────────────────────────────────────────────────
# Token per accedere al pannello admin (/admin)
# Scegli una stringa lunga e casuale — NON lasciare "admin123" in produzione
ADMIN_TOKEN=cambia-questo-con-qualcosa-di-sicuro

# ── PRODUZIONE (opzionale) ────────────────────────────────────
# Dominio del sito, per limitare il CORS
# Esempio: ALLOWED_ORIGINS=https://tuosito.it,https://www.tuosito.it
# Lascia * per sviluppo locale
ALLOWED_ORIGINS=*
