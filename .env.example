# BollettaAI — Variabili d'ambiente
# cp .env.example .env  →  poi compila i valori

# ── OBBLIGATORIO ──────────────────────────────────────────────────────────
# Chiave API Google Gemini (gratuita su https://aistudio.google.com/apikey)
GEMINI_API_KEY=la-tua-chiave-gemini-qui

# ── SICUREZZA ─────────────────────────────────────────────────────────────
# Token per accedere al pannello admin (/admin) — cambia in produzione!
ADMIN_TOKEN=cambia-questo-con-qualcosa-di-sicuro

# ── EMAIL (Resend) ─────────────────────────────────────────────────────────
# Crea un account gratuito su https://resend.com (3.000 email/mese gratis)
# Poi crea una API Key nel pannello Resend e incollala qui
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Indirizzo mittente — deve usare un dominio verificato su Resend.
# Per test usa: onboarding@resend.dev (Resend ti permette di usarlo in test)
# Per produzione: verifica il tuo dominio su resend.com/domains
FROM_EMAIL=BollettaAI <noreply@tuodominio.it>

# Tua email per ricevere notifiche quando arriva un lead "consulente"
ADMIN_EMAIL=tua@email.it

# URL pubblico del sito (usato nei link delle email e nel sitemap)
SITE_URL=https://bollette-risparmio.onrender.com

# ── CORS (opzionale) ──────────────────────────────────────────────────────
# In produzione imposta il tuo dominio, es: https://tuosito.it
# Lascia * per sviluppo locale
ALLOWED_ORIGINS=*
